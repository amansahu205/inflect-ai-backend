# Copy to `.env` or `.env.local` if you need overrides.
# Dev default: see `.env.development` (local API on port 8000).
VITE_API_URL=http://127.0.0.1:8000

# Playwright E2E (`npm run test:e2e`): uses `vite --mode e2e` + `.env.e2e` (VITE_E2E_AUTH=1).
# Set VITE_SUPABASE_URL / VITE_SUPABASE_PUBLISHABLE_KEY in `.env.local` if the client throws without them.
