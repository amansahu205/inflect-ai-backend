# ==============================
# Backend Environment Template
# Copy this file to .env and fill values.
# ==============================

# App
ENV=development
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# LLM / AI
GROQ_API_KEY=
GEMINI_API_KEY=

# Voice (TTS)
ELEVENLABS_API_KEY=
# Optional; defaults in code if empty
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Market Data
FINNHUB_KEY=
# Some endpoints/scripts use this alternate key name
FINNHUB_KEY_1=

# Research Tools
WOLFRAM_APP_ID=

# Snowflake (required for RAG + upload scripts)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=PUBLIC
