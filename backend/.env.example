# ==============================
# Backend Environment Template
# Copy this file to .env and fill values.
# ==============================

# App
ENV=development
PORT=8000
# Comma-separated exact origins. For Lovable production + previews, add production here and use regex below for *.lovableproject.com (wildcards are not valid in allow_origins).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://inflect-ai.lovable.app,https://www.inflectai.biz,https://inflectai.biz
# Regex for dynamic preview origins (comma not allowed as multi-separator — use semicolons).
# Matches https://<sub>.lovableproject.com and https://<sub>.lovable.app (Lovable preview + hosted app subdomains).
CORS_ORIGIN_REGEX=https://.*\.lovableproject\.com;https://.*\.lovable\.app

# LLM / AI
GROQ_API_KEY=
GEMINI_API_KEY=

# Voice — ElevenLabs (TTS + Scribe STT)
ELEVENLABS_API_KEY=
# TTS voice id (from ElevenLabs UI). Add to Cloud Run --set-env-vars as ELEVENLABS_VOICE_ID=...
# If unset, tts.py defaults to 21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Speech-to-text: scribe_v2 recommended (see ElevenLabs docs)
# ELEVENLABS_STT_MODEL=scribe_v2
# Optional ISO language hint, e.g. en — leave unset for auto-detect
# ELEVENLABS_STT_LANGUAGE=
# When ELEVENLABS_API_KEY is set, Groq Whisper is NOT used unless you enable fallback:
# STT_GROQ_FALLBACK=true

# Market Data
FINNHUB_KEY=
# Some endpoints/scripts use this alternate key name
FINNHUB_KEY_1=
# When Finnhub returns 0 volume, optionally backfill via yfinance (slow; Yahoo often blocks Cloud Run — leave unset/false in production)
# YFINANCE_VOLUME_BACKFILL=true

# Research Tools
WOLFRAM_APP_ID=

# Snowflake (required for RAG + upload scripts)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=PUBLIC
